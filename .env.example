# mambo-hachimi 签到凭据与配置（复制本文件为 .env 并填写）
# cp .env.example .env

# —— 必填：账号凭据 ——
MAMBO_USERNAME=你的用户名
MAMBO_PASSWORD=你的密码

# —— 选填：覆盖默认配置 ——
# 站点地址
# MAMBO_BASE_URL=https://mambo-hachimi.biliblili.uk

# 显示模式：headed（有桌面，推荐）/ xvfb（无桌面服务器）/ headless（多半过不了验证）/ auto（默认自动判断）
# MAMBO_DISPLAY=auto

# 持久化浏览器数据目录（保留登录态与 Cloudflare 通行证，强烈建议固定不变）
# MAMBO_PROFILE_DIR=./.profile

# 登录最长等待（秒）
# MAMBO_LOGIN_TIMEOUT=60
